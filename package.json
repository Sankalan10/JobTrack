{
  "name": "jobtrack-root",
  "version": "1.0.0",
  "description": "Personalized Job & Internship Application Funnel",
  "private": true,
  "scripts": {
    "setup": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "db:init": "npm run db:init --prefix backend",
    "backend": "npm start --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently --kill-others \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
